@page "/business-rule-bundles"
@using EtlAnalytics.App.Models
@using EtlAnalytics.App.Services
@using System.Text.Json
@using System.Text.Encodings.Web
@inject SqlDatabaseService DbService
@inject BusinessRuleEngine<BusinessRuleContext> Engine
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject IJSRuntime JSRuntime

<PageTitle>Business Rule Bundles</PageTitle>

<div style="display: flex; height: calc(100vh - 120px); border: 1px solid #e2e8f0; border-radius: 8px; background: #ffffff; overflow: hidden;">
    <!-- Sidebar: Bundle List -->
    <div style="width: 300px; border-right: 1px solid #e2e8f0; display: flex; flex-direction: column; background: #f8fafc;">
        <div style="padding: 1rem; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center; background: #ffffff;">
            <RadzenText TextStyle="TextStyle.Subtitle1" Style="font-weight: 700; margin: 0; color: #0f172a;">Bundles</RadzenText>
            <div style="display: flex; gap: 0.5rem;">
                <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="LoadBundlesAsync" Tooltip="Refresh List" />
                <RadzenButton Icon="add" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="CreateNewBundle" Tooltip="Create New Bundle" />
            </div>
        </div>
        <div style="flex-grow: 1; overflow-y: auto; padding: 0.5rem;">
            @if (!bundles.Any())
            {
                <div style="padding: 1rem; color: #64748b; font-size: 0.9rem; text-align: center;">No bundles found.</div>
            }
            @foreach (var bundle in bundles)
            {
                <div @onclick="() => SelectBundle(bundle.Id)" 
                     style="padding: 0.75rem 1rem; margin-bottom: 0.25rem; border-radius: 6px; cursor: pointer; transition: all 0.2s; 
                            background: @(selectedBundle?.Id == bundle.Id ? "#eff6ff" : "transparent");
                            border: 1px solid @(selectedBundle?.Id == bundle.Id ? "#bfdbfe" : "transparent");">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                        <span style="font-weight: 600; color: #1e293b; font-size: 0.9rem;">@bundle.Name</span>
                    </div>
                    <div style="font-size: 0.75rem; color: #64748b; margin-top: 0.25rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                        @bundle.UpdatedAt.ToString("MMM dd, HH:mm")
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Main Content: Sequencer & Runner -->
    <div style="flex-grow: 1; display: flex; flex-direction: column; background: #ffffff;">
        @if (selectedBundle == null)
        {
            <div style="flex-grow: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #94a3b8;">
                <span class="rzi" style="font-size: 4rem; margin-bottom: 1rem;">account_tree</span>
                <RadzenText TextStyle="TextStyle.H6" Style="color: #94a3b8;">Select a bundle to view or edit</RadzenText>
            </div>
        }
        else
        {
            <!-- Toolbar -->
            <div style="padding: 0.75rem 1.5rem; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
                <div style="display: flex; align-items: center; gap: 1rem;">
                    <RadzenText TextStyle="TextStyle.H6" Style="font-weight: 700; margin: 0; color: #0f172a;">@selectedBundle.Name</RadzenText>
                </div>
                <div style="display: flex; gap: 0.75rem; align-items: center;">
                    <RadzenButton Text="Run Bundle" Icon="play_arrow" ButtonStyle="ButtonStyle.Success" Click="RunBundle" IsBusy="@isRunning" />
                    <RadzenButton Text="Save Changes" Icon="save" ButtonStyle="ButtonStyle.Primary" Click="SaveCurrentBundle" IsBusy="@isSaving" />
                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Click="() => ConfirmDeleteAsync(selectedBundle)" Variant="Variant.Flat" />
                </div>
            </div>

            <!-- Content Splitter -->
            <div style="flex-grow: 1; display: flex; flex-direction: column; overflow: hidden;">
                <div style="flex: 1; padding: 1.5rem; display: flex; flex-direction: column; gap: 1.5rem; overflow-y: auto;">
                    
                    <!-- Metadata -->
                    <RadzenRow Gap="1rem">
                        <RadzenColumn Size="4">
                            <RadzenText TextStyle="TextStyle.Subtitle2" Style="color: #475569; font-weight: 600; margin-bottom: 0.25rem;">Bundle Name</RadzenText>
                            <RadzenTextBox @bind-Value="selectedBundle.Name" Style="width: 100%;" />
                        </RadzenColumn>
                        <RadzenColumn Size="8">
                            <RadzenText TextStyle="TextStyle.Subtitle2" Style="color: #475569; font-weight: 600; margin-bottom: 0.25rem;">Description</RadzenText>
                            <RadzenTextBox @bind-Value="selectedBundle.Description" Style="width: 100%;" />
                        </RadzenColumn>
                    </RadzenRow>

                    <!-- Sequencer -->
                    <div style="flex-grow: 1; display: flex; flex-direction: column;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                            <RadzenText TextStyle="TextStyle.Subtitle2" Style="color: #475569; font-weight: 600; margin: 0;">Execution Sequence</RadzenText>
                            <RadzenButton Text="Add Rule to Sequence" Icon="add" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Secondary" Click="AddRuleToSequence" />
                        </div>
                        
                        <div style="border: 1px solid #e2e8f0; border-radius: 8px; background: #f8fafc; padding: 1rem;">
                            @if (!selectedBundle.Items.Any())
                            {
                                <div style="padding: 2rem; text-align: center; color: #94a3b8; border: 1px dashed #cbd5e1; border-radius: 6px;">
                                    No rules in this sequence yet. Add one to get started.
                                </div>
                            }
                            else
                            {
                                <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                                    @foreach (var item in selectedBundle.Items.OrderBy(i => i.SequenceOrder))
                                    {
                                        <div style="display: flex; align-items: center; gap: 1rem; background: #ffffff; padding: 0.75rem 1rem; border: 1px solid #e2e8f0; border-radius: 6px; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
                                            <div style="width: 24px; height: 24px; border-radius: 50%; background: #6366f1; color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">
                                                @item.SequenceOrder
                                            </div>
                                            <div style="flex-grow: 1;">
                                                <RadzenDropDown TValue="int" Data="@allRules" TextProperty="Name" ValueProperty="Id" @bind-Value="item.RuleId" Style="width: 100%;" />
                                            </div>
                                            <div style="display: flex; gap: 0.25rem;">
                                                <RadzenButton Icon="arrow_upward" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.ExtraSmall" Click="() => MoveItem(item, -1)" Disabled="@(item.SequenceOrder == 1)" />
                                                <RadzenButton Icon="arrow_downward" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.ExtraSmall" Click="() => MoveItem(item, 1)" Disabled="@(item.SequenceOrder == selectedBundle.Items.Count)" />
                                                <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.ExtraSmall" Click="() => RemoveItem(item)" />
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Watch Panel -->
                <div style="height: 250px; border-top: 1px solid #e2e8f0; background: #0b1220; color: #e2e8f0; display: flex; flex-direction: column;">
                    <div style="padding: 0.5rem 1rem; border-bottom: 1px solid #1e293b; display: flex; justify-content: space-between; align-items: center;">
                        <RadzenText TextStyle="TextStyle.Caption" Style="color: #94a3b8; font-weight: 700; text-transform: uppercase;">Sequence Watch</RadzenText>
                        <RadzenButton Icon="clear_all" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.ExtraSmall" Click="() => logs.Clear()" Variant="Variant.Text" />
                    </div>
                    <div style="flex-grow: 1; display: flex; overflow: hidden;">
                        <div id="bundle-ide-log" style="flex: 1; padding: 0.75rem; overflow-y: auto; font-family: Consolas, monospace; font-size: 0.8rem; border-right: 1px solid #1e293b;">
                            @foreach (var log in logs)
                            {
                                <div style="margin-bottom: 0.15rem;">@log</div>
                            }
                        </div>
                        <div style="width: 350px; padding: 0.75rem; overflow-y: auto; background: #0f172a;">
                            <RadzenText TextStyle="TextStyle.Caption" Style="color: #64748b; font-weight: 700; margin-bottom: 0.5rem; display: block;">Final Result Preview</RadzenText>
                            @if (finalResult != null)
                            {
                                <pre style="font-size: 0.75rem; color: #38bdf8; margin: 0; white-space: pre-wrap;">@JsonSerializer.Serialize(finalResult, new JsonSerializerOptions { WriteIndented = true, Encoder = JavaScriptEncoder.UnsafeRelaxedJsonEscaping })</pre>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private List<BusinessRuleBundle> bundles = new();
    private List<BusinessRule> allRules = new();
    private BusinessRuleBundle? selectedBundle;
    
    private bool isSaving;
    private bool isRunning;
    private List<string> logs = new();
    private object? finalResult;

    protected override async Task OnInitializedAsync()
    {
        await LoadBundlesAsync();
        allRules = (await DbService.GetBusinessRulesAsync()).ToList();
    }

    private async Task LoadBundlesAsync()
    {
        bundles = (await DbService.GetBusinessRuleBundlesAsync()).ToList();
    }

    private async Task SelectBundle(int id)
    {
        selectedBundle = await DbService.GetBusinessRuleBundleByIdAsync(id);
        finalResult = null;
    }

    private void CreateNewBundle()
    {
        selectedBundle = new BusinessRuleBundle { Name = "New Bundle" };
        finalResult = null;
        logs.Clear();
    }

    private void AddRuleToSequence()
    {
        if (selectedBundle == null) return;
        var newOrder = selectedBundle.Items.Any() ? selectedBundle.Items.Max(i => i.SequenceOrder) + 1 : 1;
        selectedBundle.Items.Add(new BusinessRuleBundleItem { SequenceOrder = newOrder });
    }

    private void MoveItem(BusinessRuleBundleItem item, int direction)
    {
        if (selectedBundle == null) return;
        var targetOrder = item.SequenceOrder + direction;
        var otherItem = selectedBundle.Items.FirstOrDefault(i => i.SequenceOrder == targetOrder);
        if (otherItem != null)
        {
            otherItem.SequenceOrder = item.SequenceOrder;
            item.SequenceOrder = targetOrder;
            StateHasChanged();
        }
    }

    private void RemoveItem(BusinessRuleBundleItem item)
    {
        if (selectedBundle == null) return;
        selectedBundle.Items.Remove(item);
        // Re-index
        var ordered = selectedBundle.Items.OrderBy(i => i.SequenceOrder).ToList();
        for (int i = 0; i < ordered.Count; i++)
        {
            ordered[i].SequenceOrder = i + 1;
        }
    }

    private async Task SaveCurrentBundle()
    {
        if (selectedBundle == null || string.IsNullOrWhiteSpace(selectedBundle.Name)) return;

        isSaving = true;
        try
        {
            if (selectedBundle.Id == 0)
                await DbService.InsertBusinessRuleBundleAsync(selectedBundle);
            else
                await DbService.UpdateBusinessRuleBundleAsync(selectedBundle);

            NotificationService.Notify(NotificationSeverity.Success, "Success", "Bundle saved.");
            await LoadBundlesAsync();
            await SelectBundle(selectedBundle.Id);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
        }
        finally { isSaving = false; }
    }

    private async Task RunBundle()
    {
        if (selectedBundle == null || !selectedBundle.Items.Any()) return;

        isRunning = true;
        finalResult = null;
        logs.Clear();
        StateHasChanged();

        try
        {
            var importTimes = await DbService.GetImportTimesAsync();
            var jobs = importTimes.Any() ? await DbService.QueryJobsByImportTimeAsync(importTimes[0]) : new List<JilJob>();
            var mappings = await DbService.GetJobToPackagesAsync();
            
            var baseContext = new BusinessRuleContext
            {
                Jobs = jobs.ToList(),
                JobToPackageMappings = mappings.ToList(),
                Log = line => {
                     _ = InvokeAsync(() => {
                        logs.Add($"[{DateTime.Now:HH:mm:ss}] {line}");
                        StateHasChanged();
                        _ = JSRuntime.InvokeVoidAsync("scrollDtsxLoaderLogToBottom", "bundle-ide-log");
                    });
                }
            };

            finalResult = await Engine.ExecuteBundleAsync(selectedBundle, baseContext, 
                line => {
                    _ = InvokeAsync(() => {
                        logs.Add($"[{DateTime.Now:HH:mm:ss}] {line}");
                        StateHasChanged();
                        _ = JSRuntime.InvokeVoidAsync("scrollDtsxLoaderLogToBottom", "bundle-ide-log");
                    });
                });
        }
        catch (Exception ex)
        {
            logs.Add($"[FATAL] {ex.Message}");
        }
        finally { isRunning = false; }
    }

    private async Task ConfirmDeleteAsync(BusinessRuleBundle bundle)
    {
        var confirm = await DialogService.Confirm($"Delete bundle '{bundle.Name}'?", "Confirm");
        if (confirm == true)
        {
            await DbService.DeleteBusinessRuleBundleAsync(bundle.Id);
            selectedBundle = null;
            await LoadBundlesAsync();
        }
    }
}
