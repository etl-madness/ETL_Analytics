@page "/imported-jobs"
@page "/jil-batch-editor"
@using EtlAnalytics.App.Models
@using EtlAnalytics.App.Services
@inject SqlDatabaseService SqlDatabaseService

<PageTitle>Imported JIL Batch Editor</PageTitle>

<RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: #0f172a; margin-bottom: 0.25rem;">Imported JIL Batch Editor</RadzenText>
<RadzenText TextStyle="TextStyle.Subtitle1" Style="color: #64748b; margin-bottom: 1.5rem;">
    Select an imported JIL batch, edit job fields, and save the edited rows as a new ImportedAt UTC snapshot.
</RadzenText>

<RadzenCard Style="border: 1px solid #e2e8f0; border-radius: 8px; padding: 1.25rem; background: #ffffff; margin-bottom: 1.25rem;">
    <div style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-end;">
        <div>
            <RadzenText TextStyle="TextStyle.Subtitle2" Style="color: #475569; font-weight: 600; margin-bottom: 0.4rem; display:block;">Source ImportedAt</RadzenText>
            <RadzenDropDown TValue="string"
                            Data="@(importTimes.Select(t => new { Value = t.ToString("O"), Text = t.ToString("yyyy-MM-dd HH:mm:ss 'UTC'") }))"
                            Value="@selectedImportTime"
                            ValueProperty="Value"
                            TextProperty="Text"
                            Change="@OnImportTimeChanged"
                            Placeholder="Select source import..."
                            Style="min-width: 320px;" />
        </div>

        <div>
            <RadzenText TextStyle="TextStyle.Subtitle2" Style="color: #475569; font-weight: 600; margin-bottom: 0.4rem; display:block;">New ImportedAt (UTC)</RadzenText>
            <RadzenDatePicker TValue="DateTime?"
                              @bind-Value="newImportedAtUtc"
                              ShowTime="true"
                              DateFormat="yyyy-MM-dd HH:mm:ss"
                              HourFormat="24"
                              Style="min-width: 260px;" />
        </div>

        <div>
            <RadzenButton Text="Save as New Snapshot"
                          Icon="save"
                          ButtonStyle="ButtonStyle.Primary"
                          Click="@SaveEditedJobsAsync"
                          Disabled="@(isSaving || !editableJobs.Any() || newImportedAtUtc is null || (saveSelectedOnly && !selectedJobs.Any()))"
                          IsBusy="@isSaving" />
        </div>

        <div style="display:flex; align-items:center; gap:0.5rem; margin-left:auto;">
            <RadzenText TextStyle="TextStyle.Body2" Style="color: #475569;">Save selected rows only</RadzenText>
            <RadzenSwitch @bind-Value="saveSelectedOnly" />
        </div>
    </div>
</RadzenCard>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Flat" Style="margin-bottom: 1rem;">
        @statusMessage
    </RadzenAlert>
}

@if (isLoading)
{
    <div style="display: flex; justify-content: center; padding: 3rem 0;">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    </div>
}
else if (editableJobs.Any())
{
    <RadzenDataGrid Data="@editableJobs" TItem="JilJob" AllowFiltering="true" AllowSorting="true" AllowPaging="true" PageSize="15"
                    AllowColumnResize="true" Style="border: 1px solid #e2e8f0; border-radius: 8px;">
        <Columns>
            <RadzenDataGridColumn TItem="JilJob" Width="70px" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
                <HeaderTemplate>
                    <RadzenCheckBox TValue="bool" Value="@AreAllJobsSelected" Change="@OnSelectAllChanged" />
                </HeaderTemplate>
                <Template Context="job">
                    <RadzenCheckBox TValue="bool" Value="@IsJobSelected(job)" Change="@(value => OnRowSelectionChanged(job, value))" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="JilJob" Property="JobName" Title="Job Name" Width="220px">
                <Template Context="job">
                    <RadzenTextBox @bind-Value="job.JobName" Style="width: 100%;" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="JilJob" Property="JobType" Title="Job Type" Width="120px">
                <Template Context="job">
                    <RadzenTextBox @bind-Value="job.JobType" Style="width: 100%;" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="JilJob" Property="Machine" Title="Machine" Width="160px">
                <Template Context="job">
                    <RadzenTextBox @bind-Value="job.Machine" Style="width: 100%;" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="JilJob" Property="Owner" Title="Owner" Width="140px">
                <Template Context="job">
                    <RadzenTextBox @bind-Value="job.Owner" Style="width: 100%;" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="JilJob" Property="StartTimes" Title="Start Times" Width="130px">
                <Template Context="job">
                    <RadzenTextBox @bind-Value="job.StartTimes" Style="width: 100%;" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="JilJob" Property="StartMins" Title="Start Mins" Width="120px">
                <Template Context="job">
                    <RadzenTextBox @bind-Value="job.StartMins" Style="width: 100%;" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="JilJob" Property="Application" Title="Application" Width="140px">
                <Template Context="job">
                    <RadzenTextBox @bind-Value="job.Application" Style="width: 100%;" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="JilJob" Property="Command" Title="Command" Width="260px">
                <Template Context="job">
                    <RadzenTextBox @bind-Value="job.Command" Style="width: 100%;" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="JilJob" Property="Description" Title="Description" Width="280px">
                <Template Context="job">
                    <RadzenTextBox @bind-Value="job.Description" Style="width: 100%;" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code {
    private List<DateTime> importTimes = new();
    private string? selectedImportTime;
    private DateTime? newImportedAtUtc = DateTime.UtcNow;
    private List<JilJob> editableJobs = new();
    private List<JilJob> selectedJobs = new();
    private bool saveSelectedOnly;
    private bool isLoading;
    private bool isSaving;
    private string statusMessage = string.Empty;
    private bool AreAllJobsSelected => editableJobs.Any() && selectedJobs.Count == editableJobs.Count;

    protected override async Task OnInitializedAsync()
    {
        await LoadImportTimesAsync();
    }

    private async Task LoadImportTimesAsync()
    {
        try
        {
            importTimes = (await SqlDatabaseService.GetImportTimesAsync()).ToList();
            if (!importTimes.Any())
            {
                statusMessage = "No imported JIL snapshots were found.";
                return;
            }

            selectedImportTime = importTimes.First().ToString("O");
            await LoadJobsForSelectedImportAsync();
        }
        catch (Exception ex)
        {
            statusMessage = $"Failed to load import times: {ex.Message}";
        }
    }

    private async Task OnImportTimeChanged(object value)
    {
        selectedImportTime = value?.ToString();
        await LoadJobsForSelectedImportAsync();
    }

    private async Task LoadJobsForSelectedImportAsync()
    {
        if (string.IsNullOrWhiteSpace(selectedImportTime))
        {
            editableJobs.Clear();
            return;
        }

        if (!DateTime.TryParse(
            selectedImportTime,
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.AssumeUniversal | System.Globalization.DateTimeStyles.AdjustToUniversal,
            out var selected))
        {
            statusMessage = "Invalid selected import timestamp.";
            return;
        }

        isLoading = true;
        statusMessage = string.Empty;

        try
        {
            var rows = await SqlDatabaseService.QueryJobsByImportTimeAsync(selected);
            editableJobs = rows.Select(CloneJob).ToList();
            selectedJobs = editableJobs.ToList();
            statusMessage = $"Loaded {editableJobs.Count} jobs from {selected:yyyy-MM-dd HH:mm:ss} UTC.";

            if (!editableJobs.Any())
            {
                statusMessage = "No jobs found for selected ImportedAt value.";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Failed to load jobs: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveEditedJobsAsync()
    {
        if (!editableJobs.Any())
        {
            statusMessage = "There are no jobs to save.";
            return;
        }

        if (!newImportedAtUtc.HasValue)
        {
            statusMessage = "Select a new ImportedAt UTC value before saving.";
            return;
        }

        isSaving = true;

        try
        {
            var importedAtUtc = ToUtc(newImportedAtUtc.Value);
            importedAtUtc = importedAtUtc.AddTicks(-(importedAtUtc.Ticks % TimeSpan.TicksPerSecond));

            var sourceRows = saveSelectedOnly ? selectedJobs : editableJobs;
            var rowsToInsert = sourceRows.Select(CloneJob).ToList();
            var inserted = await SqlDatabaseService.InsertJobsAsync(rowsToInsert, importedAtUtc: importedAtUtc);

            statusMessage = $"Saved {inserted} jobs as a new snapshot at {importedAtUtc:yyyy-MM-dd HH:mm:ss} UTC.";

            await LoadImportTimesAsync();
            selectedImportTime = importedAtUtc.ToString("O");
            await LoadJobsForSelectedImportAsync();
        }
        catch (Exception ex)
        {
            statusMessage = $"Failed to save jobs: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private bool IsJobSelected(JilJob job) => selectedJobs.Contains(job);

    private void OnRowSelectionChanged(JilJob job, bool value)
    {
        if (value)
        {
            if (!selectedJobs.Contains(job))
            {
                selectedJobs.Add(job);
            }
        }
        else
        {
            selectedJobs.Remove(job);
        }
    }

    private void OnSelectAllChanged(bool value)
    {
        selectedJobs = value ? editableJobs.ToList() : new List<JilJob>();
    }

    private static DateTime ToUtc(DateTime value)
    {
        return value.Kind switch
        {
            DateTimeKind.Utc => value,
            DateTimeKind.Local => value.ToUniversalTime(),
            _ => DateTime.SpecifyKind(value, DateTimeKind.Utc)
        };
    }

    private static JilJob CloneJob(JilJob source)
    {
        return new JilJob
        {
            JobName = source.JobName,
            JobType = source.JobType,
            Command = source.Command,
            Machine = source.Machine,
            Owner = source.Owner,
            Permission = source.Permission,
            DateConditions = source.DateConditions,
            DaysOfWeek = source.DaysOfWeek,
            StartMins = source.StartMins,
            StartTimes = source.StartTimes,
            Timezone = source.Timezone,
            Description = source.Description,
            StdOutFile = source.StdOutFile,
            StdErrFile = source.StdErrFile,
            AlarmIfFail = source.AlarmIfFail,
            Application = source.Application,
            RawText = source.RawText,
            AdditionalProperties = new Dictionary<string, string>(source.AdditionalProperties, StringComparer.OrdinalIgnoreCase)
        };
    }
}
