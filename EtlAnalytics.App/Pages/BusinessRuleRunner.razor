@using EtlAnalytics.App.Models
@using EtlAnalytics.App.Services
@using System.Text.Json
@inject BusinessRuleEngine<BusinessRuleContext> Engine
@inject SqlDatabaseService DbService
@inject IJSRuntime JSRuntime

<RadzenStack Gap="1.5rem" Style="padding: 1rem;">
    <RadzenText TextStyle="TextStyle.H6" Style="color: #1e293b; font-weight: 600;">Run Rule: @Rule.Name</RadzenText>

    <RadzenCard Style="background: #0b1220; color: #e2e8f0; border-radius: 6px; padding: 0.75rem;">
        <RadzenText TextStyle="TextStyle.Subtitle2" Style="color: #94a3b8; font-weight: 600; margin-bottom: 0.5rem;">Execution Logs</RadzenText>
        <div id="rule-exec-log" style="min-height: 150px; max-height: 250px; overflow-y: auto; font-family: Consolas, monospace; font-size: 0.85rem;">
            @if (!logs.Any())
            {
                <div style="color: #64748b;">Ready to execute...</div>
            }
            @foreach (var log in logs)
            {
                <div>@log</div>
            }
        </div>
    </RadzenCard>

    @if (result != null)
    {
        <RadzenCard Style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 6px; padding: 0.75rem;">
            <RadzenText TextStyle="TextStyle.Subtitle2" Style="color: #475569; font-weight: 600; margin-bottom: 0.5rem;">Execution Result (JSON Preview)</RadzenText>
            <div style="font-family: Consolas, monospace; font-size: 0.85rem; overflow-x: auto; white-space: pre-wrap;">
                @JsonSerializer.Serialize(result, new JsonSerializerOptions { WriteIndented = true })
            </div>
        </RadzenCard>
    }

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.75rem">
        <RadzenButton Text="Close" Click="() => DialogService.Close()" ButtonStyle="ButtonStyle.Light" />
        <RadzenButton Text="Run Execution" Click="ExecuteAsync" ButtonStyle="ButtonStyle.Success" Icon="play_arrow" IsBusy="@isRunning" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public BusinessRule Rule { get; set; } = new();
    [Inject] public DialogService DialogService { get; set; } = default!;

    private List<string> logs = new();
    private object? result;
    private bool isRunning;

    private async Task ExecuteAsync()
    {
        logs.Clear();
        result = null;
        isRunning = true;

        try
        {
            // Prepare the global context for C# scripts
            BusinessRuleContext? context = null;
            if (Rule.RuleType == RuleType.CSharp)
            {
                var importTimes = await DbService.GetImportTimesAsync();
                var jobs = importTimes.Any() ? await DbService.QueryJobsByImportTimeAsync(importTimes[0]) : new List<JilJob>();
                var mappings = await DbService.GetJobToPackagesAsync();
                
                context = new BusinessRuleContext
                {
                    Jobs = jobs.ToList(),
                    JobToPackageMappings = mappings.ToList(),
                    ExecutionTime = DateTime.Now,
                    Log = line => {
                         _ = InvokeAsync(() => {
                            logs.Add($"[{DateTime.Now:HH:mm:ss}] [SCRIPT] {line}");
                            StateHasChanged();
                            _ = JSRuntime.InvokeVoidAsync("scrollDtsxLoaderLogToBottom", "rule-exec-log");
                        });
                    }
                };
            }

            result = await Engine.ExecuteRuleAsync(Rule, context, log =>
            {
                _ = InvokeAsync(() => {
                    logs.Add($"[{DateTime.Now:HH:mm:ss}] {log}");
                    StateHasChanged();
                    _ = JSRuntime.InvokeVoidAsync("scrollDtsxLoaderLogToBottom", "rule-exec-log");
                });
            });
        }
        finally
        {
            isRunning = false;
        }
    }
}
