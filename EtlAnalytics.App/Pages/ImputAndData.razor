    private async Task ImportStreamAsync(string fileName, Stream sourceStream)
    {
        try
        {
            using var stream = sourceStream;
            using var reader = new StreamReader(stream);
            var content = await reader.ReadToEndAsync();
            importResult = JilParser.Parse(content, fileName);
            statusMessage = $"Imported {importResult.Jobs.Count} jobs from {fileName}.";
            sampleFileName = fileName;
