    private List<AutoSysPackageToObject> ParseP2OCsv(string csvText)
    {
        var list = new List<AutoSysPackageToObject>();
        var lines = csvText.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.RemoveEmptyEntries);
        var utcNow = DateTime.UtcNow;
        bool isFirst = true;
        foreach (var line in lines)
        {
            var parts = line.Split(',');
            if (parts.Length < 6) continue;
            string Clean(int i) => i < parts.Length ? parts[i].Trim().Trim('"') : string.Empty;
            if (isFirst)
            {
                isFirst = false;
                if (string.Equals(Clean(0), "PackageName", StringComparison.OrdinalIgnoreCase))
                    continue;
            }
            list.Add(new AutoSysPackageToObject
            {
                PackageName = Clean(0),
                DatabaseServer = Clean(1),
                Database = Clean(2),
                Schema = Clean(3),
                ObjectName = Clean(4),
                ObjectType = Clean(5),
                ImportedAt = utcNow
            });
        }
        return list;
    }

    private async Task ExportP2OToCsvAsync()
    {
        if (p2oRows == null || !p2oRows.Any())
        {
            p2oStatusMessage = "No rows available to export.";
            return;
        }
        try
        {
            var sb = new System.Text.StringBuilder();
            sb.AppendLine("PackageName,database_server,database,schema,object_name,object_type,ImportedAt");
            foreach (var r in p2oRows)
            {
                sb.AppendLine(string.Join(",", new[]
                {
                    EscapeCsvValue(r.PackageName ?? string.Empty),
                    EscapeCsvValue(r.DatabaseServer ?? string.Empty),
                    EscapeCsvValue(r.Database ?? string.Empty),
                    EscapeCsvValue(r.Schema ?? string.Empty),
                    EscapeCsvValue(r.ObjectName ?? string.Empty),
                    EscapeCsvValue(r.ObjectType ?? string.Empty),
                    r.ImportedAt.ToString("yyyy-MM-dd HH:mm:ss")
                }));
            }
            var fileName = $"package_to_object_{DateTime.UtcNow:yyyyMMdd_HHmmss}.csv";
            await JSRuntime.InvokeVoidAsync("downloadFileFromStream", fileName, sb.ToString());
            p2oStatusMessage = $"Exported {p2oRows.Count} rows to {fileName}.";
        }
        catch (Exception ex)
        {
            p2oStatusMessage = $"Export failed: {ex.Message}";
        }
    }

