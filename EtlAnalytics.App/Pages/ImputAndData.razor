            using var stream = file.OpenReadStream(maxAllowedSize: 5_000_000);
            using var reader = new StreamReader(stream);
            var content = await reader.ReadToEndAsync();
            var list = ParseCsv(content);
            if (list.Count > 0)
            {
                var count = await SqlDatabaseService.InsertJobToPackagesAsync(list);
                mappingStatusMessage = $"Successfully imported {count} mappings from CSV.";
                await LoadMappingsAsync();
            }
            else
            {
                mappingStatusMessage = "No valid records found in the CSV file.";
            }
        }
        catch (Exception ex)
        {
            mappingStatusMessage = $"CSV Import failed: {ex.Message}";
        }
    }

    private List<AutoSysJobToPackage> ParseCsv(string csvText)
    {
        var list = new List<AutoSysJobToPackage>();
        var lines = csvText.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.RemoveEmptyEntries);
        var utcNow = DateTime.UtcNow;

        bool isFirst = true;
        foreach (var line in lines)
        {
            var parts = line.Split(',');
            if (parts.Length < 2) continue;

            var job = parts[0].Trim().Trim('"');
            var pkg = parts[1].Trim().Trim('"');

            if (isFirst)
            {
                isFirst = false;
                if (string.Equals(job, "JobName", StringComparison.OrdinalIgnoreCase) ||
                    string.Equals(job, "Job Name", StringComparison.OrdinalIgnoreCase) ||
                    string.Equals(pkg, "PackageName", StringComparison.OrdinalIgnoreCase) ||
                    string.Equals(pkg, "Package Name", StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }
            }

            if (!string.IsNullOrWhiteSpace(job) && !string.IsNullOrWhiteSpace(pkg))
            {
                list.Add(new AutoSysJobToPackage
                {
                    JobName = job,
                    PackageName = pkg,
                    ImportedAt = utcNow
                });
            }
        }
        return list;
    }

