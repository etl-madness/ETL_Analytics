            var content = await File.ReadAllTextAsync(filePath);
            importResult = JilParser.Parse(content, fileName);
            statusMessage = $"Imported {importResult.Jobs.Count} jobs from {fileName}.";
            sampleFileName = fileName;
        }
        catch (Exception ex)
        {
            statusMessage = $"Import failed: {ex.Message}";
        }
    }

    private async Task SaveToDatabaseAsync()
    {
        if (importResult?.Jobs == null || !importResult.Jobs.Any())
        {
            statusMessage = "Import a JIL file before saving.";
            return;
        }

        try
        {
            isSaving = true;
            await SqlDatabaseService.CreateTableIfNotExistsAsync();
            var inserted = await SqlDatabaseService.InsertJobsAsync(importResult.Jobs);
            statusMessage = $"Saved {inserted} jobs to the database.";
        }
        catch (Exception ex)
        {
            statusMessage = $"Save failed: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

