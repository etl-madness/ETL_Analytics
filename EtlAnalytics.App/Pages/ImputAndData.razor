    private async Task ExportToCsvAsync()
    {
        if (mappings == null || !mappings.Any())
        {
            mappingStatusMessage = "No mappings available to export.";
            return;
        }

        try
        {
            var csvBuilder = new System.Text.StringBuilder();
            csvBuilder.AppendLine("JobName,PackageName,ImportedAt");

            foreach (var mapping in mappings)
            {
                var escapedJobName = EscapeCsvValue(mapping.JobName);
                var escapedPackageName = EscapeCsvValue(mapping.PackageName);
                var formattedDate = mapping.ImportedAt.ToString("yyyy-MM-dd HH:mm:ss");

                csvBuilder.AppendLine($"{escapedJobName},{escapedPackageName},{formattedDate}");
            }

            var fileName = $"job_to_package_mappings_{DateTime.UtcNow:yyyyMMdd_HHmmss}.csv";
            await JSRuntime.InvokeVoidAsync("downloadFileFromStream", fileName, csvBuilder.ToString());
            mappingStatusMessage = $"Exported {mappings.Count} mappings to {fileName}.";
        }
        catch (Exception ex)
        {
            mappingStatusMessage = $"Export failed: {ex.Message}";
        }
    }

    private string EscapeCsvValue(string value)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        if (value.Contains(",") || value.Contains("\"") || value.Contains("\r") || value.Contains("\n"))
        {
            var replaced = value.Replace("\"", "\"\"");
            return "\"" + replaced + "\"";
        }
        return value;
    }

