    {
        var list = new List<AutoSysRuntimeJob>();
        var lines = csvText.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.RemoveEmptyEntries);
        var utcNow = DateTime.UtcNow;
        bool isFirst = true;
        foreach (var line in lines)
        {
            var parts = line.Split(',');
            if (parts.Length < 3) continue;
            string Clean(int i) => i < parts.Length ? parts[i].Trim().Trim('"') : string.Empty;
            if (isFirst)
            {
                isFirst = false;
                if (string.Equals(Clean(0), "JobName", StringComparison.OrdinalIgnoreCase))
                    continue;
            }

            decimal? runTime = null;
            if (decimal.TryParse(Clean(2), out var rt))
            {
                runTime = rt;
            }

            DateTime insertedAt = utcNow;
            if (parts.Length >= 4 && DateTime.TryParse(Clean(3), out var dt))
            {
                insertedAt = dt;
            }

            list.Add(new AutoSysRuntimeJob
            {
                JobName = Clean(0),
                JobStatus = Clean(1),
                RunTimeInMinutes = runTime,
                InsertedAt = insertedAt
            });
        }
        return list;
    }

    private async Task ExportRuntimeToCsvAsync()
    {
        if (runtimeRows == null || !runtimeRows.Any())
        {
            runtimeStatusMessage = "No rows available to export.";
            return;
        }
        try
        {
            var sb = new System.Text.StringBuilder();
            sb.AppendLine("JobName,JobStatus,RunTimeInMinutes,InsertedAt");
            foreach (var r in runtimeRows)
            {
                sb.AppendLine(string.Join(",", new[]
                {
                    EscapeCsvValue(r.JobName ?? string.Empty),
                    EscapeCsvValue(r.JobStatus ?? string.Empty),
                    EscapeCsvValue(r.RunTimeInMinutes?.ToString() ?? string.Empty),
                    r.InsertedAt.ToString("yyyy-MM-dd HH:mm:ss")
                }));
            }
            var fileName = $"runtime_jobs_{DateTime.UtcNow:yyyyMMdd_HHmmss}.csv";
            await JSRuntime.InvokeVoidAsync("downloadFileFromStream", fileName, sb.ToString());
            runtimeStatusMessage = $"Exported {runtimeRows.Count} rows to {fileName}.";
        }
        catch (Exception ex)
        {
            runtimeStatusMessage = $"Export failed: {ex.Message}";
        }
    }

    private string GetRuntimeSaveButtonText()
        => $"Save Manual Entries ({runtimeUnsaved.Count})";

    private bool IsRuntimeExportDisabled => runtimeRows == null || !runtimeRows.Any();
}

