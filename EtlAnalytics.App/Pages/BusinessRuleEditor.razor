@using EtlAnalytics.App.Models
@using EtlAnalytics.App.Services
@inject DialogService DialogService
@inject SqlDatabaseService DbService

<RadzenStack Gap="1.5rem" Style="padding: 1rem;">
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="8">
            <RadzenText TextStyle="TextStyle.Subtitle2" Style="color: #475569; font-weight: 600; margin-bottom: 0.25rem;">Rule Name</RadzenText>
            <RadzenTextBox @bind-Value="Rule.Name" Style="width: 100%;" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenText TextStyle="TextStyle.Subtitle2" Style="color: #475569; font-weight: 600; margin-bottom: 0.25rem;">Rule Type</RadzenText>
            <RadzenDropDown @bind-Value="Rule.RuleType" Data="@ruleTypes" Style="width: 100%;" />
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow>
        <RadzenColumn Size="12">
            <RadzenText TextStyle="TextStyle.Subtitle2" Style="color: #475569; font-weight: 600; margin-bottom: 0.25rem;">Description</RadzenText>
            <RadzenTextArea @bind-Value="Rule.Description" Style="width: 100%; height: 80px;" />
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow>
        <RadzenColumn Size="12">
            <RadzenText TextStyle="TextStyle.Subtitle2" Style="color: #475569; font-weight: 600; margin-bottom: 0.25rem;">Code (@Rule.RuleType)</RadzenText>
            <RadzenTextArea @bind-Value="Rule.Code" 
                            Style="width: 100%; height: 300px; font-family: Consolas, monospace; background: #0f172a; color: #f8fafc;" 
                            Placeholder="Enter your TSQL or C# code here..." />
        </RadzenColumn>
    </RadzenRow>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.75rem">
        <RadzenButton Text="Cancel" Click="() => DialogService.Close(null)" ButtonStyle="ButtonStyle.Light" />
        <RadzenButton Text="Save Rule" Click="SaveAsync" ButtonStyle="ButtonStyle.Primary" Icon="save" IsBusy="@isSaving" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public BusinessRule Rule { get; set; } = new();
    private bool isSaving;
    private List<RuleType> ruleTypes = Enum.GetValues<RuleType>().ToList();

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(Rule.Name) || string.IsNullOrWhiteSpace(Rule.Code))
        {
            return;
        }

        isSaving = true;
        try
        {
            if (Rule.Id == 0)
            {
                await DbService.InsertBusinessRuleAsync(Rule);
            }
            else
            {
                await DbService.UpdateBusinessRuleAsync(Rule);
            }
            DialogService.Close(Rule);
        }
        finally
        {
            isSaving = false;
        }
    }
}
