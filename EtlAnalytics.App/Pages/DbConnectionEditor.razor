@using EtlAnalytics.App.Models
@using EtlAnalytics.App.Services
@inject DialogService DialogService
@inject SqlDatabaseService DbService

<RadzenStack Gap="1.5rem" Style="padding: 1rem;">
    <RadzenRow>
        <RadzenColumn Size="12" SizeMD="8">
            <RadzenText TextStyle="TextStyle.Subtitle2" Style="color: #475569; font-weight: 600; margin-bottom: 0.25rem;">Connection Name</RadzenText>
            <RadzenTextBox @bind-Value="Connection.Name" Style="width: 100%;" Placeholder="e.g. AuditDatabase" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenText TextStyle="TextStyle.Subtitle2" Style="color: #475569; font-weight: 600; margin-bottom: 0.25rem;">Provider Type</RadzenText>
            <RadzenDropDown @bind-Value="Connection.ProviderType" Data="@providerTypes" Style="width: 100%;" />
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow>
        <RadzenColumn Size="12">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem;">
                <RadzenText TextStyle="TextStyle.Subtitle2" Style="color: #475569; font-weight: 600; margin: 0;">Connection String</RadzenText>
                <RadzenCheckBox @bind-Value="showConnectionString" Name="ShowSecret" TValue="bool" />
                <RadzenLabel Text="Show Secret" Component="ShowSecret" Style="font-size: 0.75rem; color: #64748b; margin-left: 0.25rem;" />
            </div>
            @if (showConnectionString)
            {
                <RadzenTextArea @bind-Value="Connection.ConnectionString" Style="width: 100%; height: 100px; font-family: Consolas, monospace;" 
                                Placeholder="Server=myServerAddress;Database=myDataBase;Trusted_Connection=True;" />
            }
            else
            {
                <RadzenPassword @bind-Value="Connection.ConnectionString" Style="width: 100%; font-family: Consolas, monospace;" 
                                Placeholder="Connection string is hidden" />
            }
        </RadzenColumn>
    </RadzenRow>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.75rem">
        <RadzenButton Text="Cancel" Click="() => DialogService.Close(null)" ButtonStyle="ButtonStyle.Light" />
        <RadzenButton Text="Save Connection" Click="SaveAsync" ButtonStyle="ButtonStyle.Primary" Icon="save" IsBusy="@isSaving" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public DbConnectionDefinition Connection { get; set; } = new();
    private bool isSaving;
    private bool showConnectionString;
    private List<string> providerTypes = new() { "SqlServer", "Postgres", "MySql" };

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(Connection.Name) || string.IsNullOrWhiteSpace(Connection.ConnectionString))
        {
            return;
        }

        isSaving = true;
        try
        {
            if (Connection.Id == 0)
            {
                await DbService.InsertDbConnectionAsync(Connection);
            }
            else
            {
                await DbService.UpdateDbConnectionAsync(Connection);
            }
            DialogService.Close(Connection);
        }
        finally
        {
            isSaving = false;
        }
    }
}
