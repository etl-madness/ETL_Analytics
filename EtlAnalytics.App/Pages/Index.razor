@page "/"
@using EtlAnalytics.App.Models
@using EtlAnalytics.App.Services
@using Radzen.Blazor
@inject SqlDatabaseService SqlDatabaseService
@inject NavigationManager NavigationManager

<PageTitle>Dashboard — ETL_Analytics</PageTitle>

<style>
    .hero-banner {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1e40af 100%);
        border-radius: 12px;
        padding: 2.5rem 2rem;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
    }

    .hero-banner::before {
        content: '';
        position: absolute;
        top: -60px;
        right: -60px;
        width: 240px;
        height: 240px;
        background: radial-gradient(circle, rgba(99,102,241,0.3) 0%, transparent 70%);
        border-radius: 50%;
    }

    .hero-banner::after {
        content: '';
        position: absolute;
        bottom: -40px;
        left: 40%;
        width: 160px;
        height: 160px;
        background: radial-gradient(circle, rgba(59,130,246,0.2) 0%, transparent 70%);
        border-radius: 50%;
    }

    .stat-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 1.5rem;
        box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        transition: transform 0.18s ease, box-shadow 0.18s ease;
        cursor: default;
    }

    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        margin-bottom: 1rem;
    }

    .feature-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 1.75rem;
        box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
        cursor: pointer;
        text-decoration: none;
        display: block;
        height: 100%;
    }

    .feature-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0,0,0,0.12);
        border-color: #6366f1;
        text-decoration: none;
    }

    .feature-icon {
        width: 56px;
        height: 56px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        margin-bottom: 1.25rem;
    }

    .pipeline-step {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 0.875rem 0;
    }

    .pipeline-step:not(:last-child) {
        border-bottom: 1px dashed #e2e8f0;
    }

    .step-num {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #6366f1;
        color: white;
        font-size: 0.8rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .db-status-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 6px;
    }

    .pulse {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    .chip {
        display: inline-block;
        background: #f1f5f9;
        color: #475569;
        border-radius: 999px;
        padding: 0.2rem 0.75rem;
        font-size: 0.75rem;
        font-weight: 600;
    }
</style>

<!-- ── Hero Banner ── -->
<div class="hero-banner">
    <div style="position: relative; z-index: 1;">
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
            <span style="background: rgba(99,102,241,0.25); color: #a5b4fc; border-radius: 999px; padding: 0.2rem 0.9rem; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.05em;">ETL ANALYTICS PLATFORM</span>
        </div>
        <h1 style="color: #ffffff; font-size: 2rem; font-weight: 800; margin: 0 0 0.5rem; letter-spacing: -0.5px;">ETL_Analytics</h1>
        <p style="color: #94a3b8; margin: 0 0 1.75rem; max-width: 560px; font-size: 1rem; line-height: 1.6;">
            End-to-end visibility into your AutoSys job estate — import JIL definitions, map jobs to SSIS packages and database objects, and visualize scheduling conflicts before they become incidents.
        </p>
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
            <RadzenButton Text="Import &amp; Data" Icon="storage" Click="@(() => NavigationManager.NavigateTo("/import-and-data"))"
                          Style="background: #6366f1; color: white; border: none; border-radius: 8px; padding: 0.6rem 1.25rem; font-weight: 600; box-shadow: 0 4px 14px rgba(99,102,241,0.4);" />
            <RadzenButton Text="View Schedule" Icon="event" Click="@(() => NavigationManager.NavigateTo("/scheduling"))"
                          Style="background: rgba(255,255,255,0.12); color: #e2e8f0; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; padding: 0.6rem 1.25rem; font-weight: 600;" />
            <RadzenButton Text="DTSX SQL View" Icon="table_view" Click="@(() => NavigationManager.NavigateTo("/dtsx-sql-view"))"
                          Style="background: rgba(255,255,255,0.12); color: #e2e8f0; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; padding: 0.6rem 1.25rem; font-weight: 600;" />
        </div>
    </div>
</div>

<!-- ── KPI Stat Cards ── -->
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 1.25rem; margin-bottom: 2rem;">

    <div class="stat-card">
        <div class="stat-icon" style="background: #ede9fe;">
            <span class="rzi" style="color: #7c3aed;">work</span>
        </div>
        <div style="font-size: 1.8rem; font-weight: 800; color: #0f172a; line-height: 1;">@jilJobCount.ToString("N0")</div>
        <div style="color: #64748b; font-size: 0.85rem; margin-top: 0.35rem; font-weight: 500;">Jobs in Latest Import</div>
        @if (jilImportCount > 0)
        {
            <div class="chip" style="margin-top: 0.6rem;">@jilImportCount import batch@(jilImportCount == 1 ? "" : "es")</div>
        }
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background: #dbeafe;">
            <span class="rzi" style="color: #1d4ed8;">link</span>
        </div>
        <div style="font-size: 1.8rem; font-weight: 800; color: #0f172a; line-height: 1;">@jobToPackageCount.ToString("N0")</div>
        <div style="color: #64748b; font-size: 0.85rem; margin-top: 0.35rem; font-weight: 500;">Job → Package Mappings</div>
        @if (jobToPackageCount > 0)
        {
            <div class="chip" style="margin-top: 0.6rem; background: #dbeafe; color: #1d4ed8;">configured</div>
        }
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background: #dcfce7;">
            <span class="rzi" style="color: #15803d;">table_chart</span>
        </div>
        <div style="font-size: 1.8rem; font-weight: 800; color: #0f172a; line-height: 1;">@packageToObjectCount.ToString("N0")</div>
        <div style="color: #64748b; font-size: 0.85rem; margin-top: 0.35rem; font-weight: 500;">Package → Object Mappings</div>
        @if (packageToObjectCount > 0)
        {
            <div class="chip" style="margin-top: 0.6rem; background: #dcfce7; color: #15803d;">mapped</div>
        }
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background: #fef3c7;">
            <span class="rzi" style="color: #b45309;">schedule</span>
        </div>
        <div style="font-size: 1.8rem; font-weight: 800; color: #0f172a; line-height: 1;">@scheduledJobCount.ToString("N0")</div>
        <div style="color: #64748b; font-size: 0.85rem; margin-top: 0.35rem; font-weight: 500;">Jobs with Schedules</div>
        @if (scheduledJobCount > 0)
        {
            <div class="chip" style="margin-top: 0.6rem; background: #fef3c7; color: #b45309;">active</div>
        }
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background: #fee2e2;">
            <span class="rzi" style="color: #dc2626;">warning</span>
        </div>
        <div style="font-size: 1.8rem; font-weight: 800; color: #0f172a; line-height: 1;">@currentConflictCount.ToString("N0")</div>
        <div style="color: #64748b; font-size: 0.85rem; margin-top: 0.35rem; font-weight: 500;">Current Conflicts</div>
        @if (currentConflictCount > 0)
        {
            <div class="chip" style="margin-top: 0.6rem; background: #fee2e2; color: #b91c1c;">attention</div>
        }
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background: #e0f2fe;">
            <span class="rzi" style="color: #0369a1;">dataset</span>
        </div>
        <div style="font-size: 1.8rem; font-weight: 800; color: #0f172a; line-height: 1;">@dtsxSqlRowCount.ToString("N0")</div>
        <div style="color: #64748b; font-size: 0.85rem; margin-top: 0.35rem; font-weight: 500;">DTSX SQL View Rows</div>
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background: #fdf2f8;">
            <span class="rzi" style="color: #db2777;">script</span>
        </div>
        <div style="font-size: 1.8rem; font-weight: 800; color: #0f172a; line-height: 1;">@businessRuleCount.ToString("N0")</div>
        <div style="color: #64748b; font-size: 0.85rem; margin-top: 0.35rem; font-weight: 500;">Active Business Rules</div>
        @if (businessRuleCount > 0)
        {
            <div class="chip" style="margin-top: 0.6rem; background: #fdf2f8; color: #db2777;">dynamic</div>
        }
    </div>

    <div class="stat-card">
        <div class="stat-icon" style="background: #f0f9ff;">
            <span class="rzi" style="color: #0369a1;">account_tree</span>
        </div>
        <div style="font-size: 1.8rem; font-weight: 800; color: #0f172a; line-height: 1;">@bundleCount.ToString("N0")</div>
        <div style="color: #64748b; font-size: 0.85rem; margin-top: 0.35rem; font-weight: 500;">Rule Bundles</div>
        @if (bundleCount > 0)
        {
            <div class="chip" style="margin-top: 0.6rem; background: #e0f2fe; color: #0369a1;">sequenced</div>
        }
    </div>
 
    <div class="stat-card">
        <div class="stat-icon" style="background: #f1f5f9;">
            <span class="rzi" style="color: #475569;">database</span>
        </div>
        <div style="font-size: 1.8rem; font-weight: 800; color: #0f172a; line-height: 1;">@dbConnectionCount.ToString("N0")</div>
        <div style="color: #64748b; font-size: 0.85rem; margin-top: 0.35rem; font-weight: 500;">Secure DB Connections</div>
        @if (dbConnectionCount > 0)
        {
            <div class="chip" style="margin-top: 0.6rem; background: #f1f5f9; color: #475569;">encrypted</div>
        }
    </div>

</div>

<!-- ── Feature Cards + Pipeline ── -->
<RadzenRow Gap="1.5rem" class="mb-4">

    <RadzenColumn Size="12" SizeMD="8">
        <RadzenCard Style="border: 1px solid #e2e8f0; border-radius: 10px; padding: 1.75rem; background: #ffffff; box-shadow: 0 1px 4px rgba(0,0,0,0.06); height: 100%;">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;">
                <span class="rzi" style="color: #6366f1; font-size: 1.3rem;">grid_view</span>
                <RadzenText TextStyle="TextStyle.H6" Style="color: #1e293b; font-weight: 700; margin: 0;">Platform Capabilities</RadzenText>
            </div>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">

                <div @onclick="@(() => NavigationManager.NavigateTo("/import-and-data"))" class="feature-card" style="padding: 1.25rem;">
                    <div class="feature-icon" style="background: #f5f3ff; width: 44px; height: 44px; font-size: 1.2rem; margin-bottom: 0.875rem;">
                        <span class="rzi" style="color: #7c3aed;">upload_file</span>
                    </div>
                    <div style="font-weight: 700; color: #1e293b; margin-bottom: 0.3rem; font-size: 0.95rem;">JIL Importer</div>
                    <div style="color: #64748b; font-size: 0.82rem; line-height: 1.5;">Parse and persist AutoSys JIL job definitions into SQL Server from file or sample data.</div>
                </div>

                <div @onclick="@(() => NavigationManager.NavigateTo("/import-and-data"))" class="feature-card" style="padding: 1.25rem;">
                    <div class="feature-icon" style="background: #eff6ff; width: 44px; height: 44px; font-size: 1.2rem; margin-bottom: 0.875rem;">
                        <span class="rzi" style="color: #1d4ed8;">link</span>
                    </div>
                    <div style="font-weight: 700; color: #1e293b; margin-bottom: 0.3rem; font-size: 0.95rem;">Job–Package Mapping</div>
                    <div style="color: #64748b; font-size: 0.82rem; line-height: 1.5;">Associate AutoSys jobs with SSIS packages via CSV import or manual grid entry.</div>
                </div>

                <div @onclick="@(() => NavigationManager.NavigateTo("/import-and-data"))" class="feature-card" style="padding: 1.25rem;">
                    <div class="feature-icon" style="background: #f0fdf4; width: 44px; height: 44px; font-size: 1.2rem; margin-bottom: 0.875rem;">
                        <span class="rzi" style="color: #15803d;">table_chart</span>
                    </div>
                    <div style="font-weight: 700; color: #1e293b; margin-bottom: 0.3rem; font-size: 0.95rem;">Package–Object Mapping</div>
                    <div style="color: #64748b; font-size: 0.82rem; line-height: 1.5;">Track which database objects each SSIS package reads from or writes to.</div>
                </div>

                <div @onclick="@(() => NavigationManager.NavigateTo("/scheduling"))" class="feature-card" style="padding: 1.25rem;">
                    <div class="feature-icon" style="background: #fffbeb; width: 44px; height: 44px; font-size: 1.2rem; margin-bottom: 0.875rem;">
                        <span class="rzi" style="color: #b45309;">event</span>
                    </div>
                    <div style="font-weight: 700; color: #1e293b; margin-bottom: 0.3rem; font-size: 0.95rem;">Schedule Visualizer</div>
                    <div style="color: #64748b; font-size: 0.82rem; line-height: 1.5;">24-hour timeline view of job runs with overlap detection and runtime duration overlays.</div>
                </div>

                <div @onclick="@(() => NavigationManager.NavigateTo("/dtsx-loader-settings"))" class="feature-card" style="padding: 1.25rem;">
                    <div class="feature-icon" style="background: #f5f3ff; width: 44px; height: 44px; font-size: 1.2rem; margin-bottom: 0.875rem;">
                        <span class="rzi" style="color: #7c3aed;">settings</span>
                    </div>
                    <div style="font-weight: 700; color: #1e293b; margin-bottom: 0.3rem; font-size: 0.95rem;">DTSX Loader</div>
                    <div style="color: #64748b; font-size: 0.82rem; line-height: 1.5;">Configure and execute DTSXDataLoader directly from this app with live output.</div>
                </div>

                <div @onclick="@(() => NavigationManager.NavigateTo("/dtsx-sql-view"))" class="feature-card" style="padding: 1.25rem;">
                    <div class="feature-icon" style="background: #ecfeff; width: 44px; height: 44px; font-size: 1.2rem; margin-bottom: 0.875rem;">
                        <span class="rzi" style="color: #0e7490;">table_view</span>
                    </div>
                    <div style="font-weight: 700; color: #1e293b; margin-bottom: 0.3rem; font-size: 0.95rem;">DTSX SQL View</div>
                    <div style="color: #64748b; font-size: 0.82rem; line-height: 1.5;">Review source and resolved SQL from <code>dbo.DTSX_SQL_View</code> in a searchable grid.</div>
                </div>

                <div @onclick="@(() => NavigationManager.NavigateTo("/business-rules"))" class="feature-card" style="padding: 1.25rem;">
                    <div class="feature-icon" style="background: #fff1f2; width: 44px; height: 44px; font-size: 1.2rem; margin-bottom: 0.875rem;">
                        <span class="rzi" style="color: #e11d48;">script</span>
                    </div>
                    <div style="font-weight: 700; color: #1e293b; margin-bottom: 0.3rem; font-size: 0.95rem;">Business Rules</div>
                    <div style="color: #64748b; font-size: 0.82rem; line-height: 1.5;">Manage and execute dynamic TSQL and C# business logic with versioning and watch logs.</div>
                </div>
 
                <div @onclick="@(() => NavigationManager.NavigateTo("/business-rule-bundles"))" class="feature-card" style="padding: 1.25rem;">
                    <div class="feature-icon" style="background: #f0f9ff; width: 44px; height: 44px; font-size: 1.2rem; margin-bottom: 0.875rem;">
                        <span class="rzi" style="color: #0369a1;">account_tree</span>
                    </div>
                    <div style="font-weight: 700; color: #1e293b; margin-bottom: 0.3rem; font-size: 0.95rem;">Rule Bundles</div>
                    <div style="color: #64748b; font-size: 0.82rem; line-height: 1.5;">Sequence multiple rules into complex workflows with stateful data piping between steps.</div>
                </div>

                <div @onclick="@(() => NavigationManager.NavigateTo("/db-connections"))" class="feature-card" style="padding: 1.25rem;">
                    <div class="feature-icon" style="background: #f1f5f9; width: 44px; height: 44px; font-size: 1.2rem; margin-bottom: 0.875rem;">
                        <span class="rzi" style="color: #475569;">database</span>
                    </div>
                    <div style="font-weight: 700; color: #1e293b; margin-bottom: 0.3rem; font-size: 0.95rem;">DB Connections</div>
                    <div style="color: #64748b; font-size: 0.82rem; line-height: 1.5;">Manage external database connections securely with AES-256 encryption at rest.</div>
                </div>

            </div>
        </RadzenCard>
    </RadzenColumn>

    <RadzenColumn Size="12" SizeMD="4">
        <RadzenCard Style="border: 1px solid #e2e8f0; border-radius: 10px; padding: 1.75rem; background: #ffffff; box-shadow: 0 1px 4px rgba(0,0,0,0.06); height: 100%;">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;">
                <span class="rzi" style="color: #6366f1; font-size: 1.3rem;">route</span>
                <RadzenText TextStyle="TextStyle.H6" Style="color: #1e293b; font-weight: 700; margin: 0;">Typical Workflow</RadzenText>
            </div>

            <div class="pipeline-step">
                <div class="step-num">1</div>
                <div>
                    <div style="font-weight: 600; color: #1e293b; font-size: 0.88rem;">Import JIL File</div>
                    <div style="color: #64748b; font-size: 0.8rem; line-height: 1.5; margin-top: 2px;">Upload your AutoSys JIL file. Jobs are parsed and saved to <code style="background:#f1f5f9;padding:1px 4px;border-radius:3px;font-size:0.78rem;">AutoSysJilJobs</code>.</div>
                </div>
            </div>
            <div class="pipeline-step">
                <div class="step-num">2</div>
                <div>
                    <div style="font-weight: 600; color: #1e293b; font-size: 0.88rem;">Map Jobs to Packages</div>
                    <div style="color: #64748b; font-size: 0.8rem; line-height: 1.5; margin-top: 2px;">Load or manually create job→SSIS package associations. Export to CSV for sharing.</div>
                </div>
            </div>
            <div class="pipeline-step">
                <div class="step-num">3</div>
                <div>
                    <div style="font-weight: 600; color: #1e293b; font-size: 0.88rem;">Map Packages to Objects</div>
                    <div style="color: #64748b; font-size: 0.8rem; line-height: 1.5; margin-top: 2px;">Record which database tables and views each SSIS package touches.</div>
                </div>
            </div>
            <div class="pipeline-step">
                <div class="step-num">4</div>
                <div>
                    <div style="font-weight: 600; color: #1e293b; font-size: 0.88rem;">Run DTSX Loader</div>
                    <div style="color: #64748b; font-size: 0.8rem; line-height: 1.5; margin-top: 2px;">Set loader options, execute DTSXDataLoader, and watch log output in real time.</div>
                </div>
            </div>
            <div class="pipeline-step">
                <div class="step-num">5</div>
                <div>
                    <div style="font-weight: 600; color: #1e293b; font-size: 0.88rem;">Analyze the Schedule</div>
                    <div style="color: #64748b; font-size: 0.8rem; line-height: 1.5; margin-top: 2px;">Use the scheduling view to spot job overlaps and plan capacity before go-live.</div>
                </div>
            </div>
            <div class="pipeline-step">
                <div class="step-num">6</div>
                <div>
                    <div style="font-weight: 600; color: #1e293b; font-size: 0.88rem;">Automate with Bundles</div>
                    <div style="color: #64748b; font-size: 0.8rem; line-height: 1.5; margin-top: 2px;">Sequence audits and validation rules into automated pipeline checks.</div>
                </div>
            </div>

        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

<!-- ── Database Status Banner ── -->
<RadzenCard Style="border: 1px solid #e2e8f0; border-radius: 10px; padding: 1.25rem 1.75rem; background: #ffffff; box-shadow: 0 1px 4px rgba(0,0,0,0.06); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
    <div style="display: flex; align-items: center; gap: 0.75rem;">
        <span class="db-status-dot pulse" style="background: @(isDbOnline ? "#22c55e" : "#ef4444");"></span>
        <span style="font-weight: 600; color: #1e293b; font-size: 0.9rem;">
            Database: @(isDbOnline ? "Connected" : "Offline")
        </span>
        @if (!string.IsNullOrWhiteSpace(dbError))
        {
            <span style="color: #ef4444; font-size: 0.8rem;">— @dbError</span>
        }
    </div>
    <div style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
        <div style="font-size: 0.82rem; color: #64748b;">
            <span style="font-weight: 600; color: #1e293b;">Core Objects: </span>
            AutoSysJilJobs · AutoSysJobToPackage · AutoSysPackageToObject · AutoSysRuntimeJobs · DTSX_SQL_View · BusinessRules · BusinessRuleBundles
        </div>
    </div>
</RadzenCard>

@code {
    private int jilJobCount;
    private int jilImportCount;
    private int jobToPackageCount;
    private int packageToObjectCount;
    private int scheduledJobCount;
    private int currentConflictCount;
    private int dtsxSqlRowCount;
    private int businessRuleCount;
    private int bundleCount;
    private int dbConnectionCount;
    private bool isDbOnline;
    private string dbError = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardStatsAsync();
    }

    private async Task LoadDashboardStatsAsync()
    {
        try
        {
            // Ensure reference tables exist (idempotent)
            await SqlDatabaseService.CreateJobToPackageTableIfNotExistsAsync();
            await SqlDatabaseService.CreatePackageToObjectTableIfNotExistsAsync();

            // Job counts
            var importTimes = await SqlDatabaseService.GetImportTimesAsync();
            jilImportCount = importTimes.Count;

            if (importTimes.Any())
            {
                // Count total JIL jobs across all batches (use most-recent batch for scheduled count)
                var latestBatch = await SqlDatabaseService.QueryJobsByImportTimeAsync(importTimes[0]);
                jilJobCount = latestBatch.Count;
                scheduledJobCount = latestBatch.Count(j =>
                    !string.IsNullOrWhiteSpace(j.StartTimes) || !string.IsNullOrWhiteSpace(j.StartMins));
            }

            // Mapping counts
            var j2p = await SqlDatabaseService.GetJobToPackagesAsync();
            jobToPackageCount = j2p.Count;

            var p2o = await SqlDatabaseService.GetPackageToObjectsAsync();
            packageToObjectCount = p2o.Count;

            try
            {
                var conflicts = await SqlDatabaseService.GetCurrentConflictingJobsAsync();
                currentConflictCount = conflicts.Count;
            }
            catch
            {
                currentConflictCount = 0;
            }

            try
            {
                var dtsxRows = await SqlDatabaseService.GetDtsxSqlViewRowsAsync();
                dtsxSqlRowCount = dtsxRows.Count;
            }
            catch
            {
                dtsxSqlRowCount = 0;
            }

            try
            {
                var businessRules = await SqlDatabaseService.GetBusinessRulesAsync();
                businessRuleCount = businessRules.Count;
            }
            catch
            {
                businessRuleCount = 0;
            }

            try
            {
                var bundles = await SqlDatabaseService.GetBusinessRuleBundlesAsync();
                bundleCount = bundles.Count;
            }
            catch
            {
                bundleCount = 0;
            }

            try
            {
                var conns = await SqlDatabaseService.GetAllDbConnectionsAsync();
                dbConnectionCount = conns.Count();
            }
            catch
            {
                dbConnectionCount = 0;
            }
 
            isDbOnline = true;
        }
        catch (Exception ex)
        {
            isDbOnline = false;
            dbError = ex.Message.Length > 80 ? ex.Message[..80] + "…" : ex.Message;
        }
    }
}
