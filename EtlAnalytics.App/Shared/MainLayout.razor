@inherits LayoutComponentBase

<PageTitle>ETL_Analytics</PageTitle>

<RadzenLayout Style="grid-template-areas: 'rz-header rz-header' 'rz-sidebar rz-body'; grid-template-columns: auto 1fr; grid-template-rows: auto 1fr; height: 100vh;">
    <RadzenHeader Style="background: linear-gradient(135deg, #1e293b, #0f172a); border-bottom: 1px solid #334155; padding: 0.75rem 1.5rem; display: flex; align-items: center; justify-content: space-between;">
        <div style="display: flex; align-items: center; gap: 1rem;">
            <RadzenSidebarToggle Click="@(() => sidebarExpanded = !sidebarExpanded)" Style="color: #cbd5e1; background: transparent; border: none; font-size: 1.25rem; cursor: pointer;" />
            <RadzenText TextStyle="TextStyle.H5" Style="color: #ffffff; font-weight: 700; margin: 0; letter-spacing: 0.5px;">AutoSys JIL Analytics</RadzenText>
        </div>
        <div style="display: flex; align-items: center; gap: 1rem;">
            <RadzenBadge Text="v1.0.0" IsPill="true" BadgeStyle="BadgeStyle.Secondary" />
        </div>
    </RadzenHeader>

    <RadzenSidebar @bind-Expanded="@sidebarExpanded" Style="background: #0f172a; border-right: 1px solid #334155; width: 260px;">
        <RadzenPanelMenu Style="background: transparent;">
            <RadzenPanelMenuItem Text="Dashboard" Path="" Icon="home" Style="color: #94a3b8; font-weight: 500;" />
            <RadzenPanelMenuItem Text="Import &amp; Data" Path="import-and-data" Icon="storage" Style="color: #94a3b8; font-weight: 500;" />

            <RadzenPanelMenuItem Text="Jil Editor" Path="imported-jobs" Icon="edit" Style="color: #94a3b8; font-weight: 500;" />
            <RadzenPanelMenuItem Text="Scheduling" Path="scheduling" Icon="event" Style="color: #94a3b8; font-weight: 500;" />

            <RadzenPanelMenuItem Text="Data Conflicts" Path="data-conflicts" Icon="grid_on" Style="color: #94a3b8; font-weight: 500;" />
            <RadzenPanelMenuItem Text="DTSX SQL View" Path="dtsx-sql-view" Icon="table_view" Style="color: #94a3b8; font-weight: 500;" />
            <RadzenPanelMenuItem Text="Business Rules" Path="business-rules" Icon="description" Style="color: #94a3b8; font-weight: 500;" />
            <RadzenPanelMenuItem Text="Rule Bundles" Path="business-rule-bundles" Icon="account_tree" Style="color: #94a3b8; font-weight: 500;" />
            <RadzenPanelMenuItem Text="DTSX Loader" Path="dtsx-loader-settings" Icon="settings" Style="color: #94a3b8; font-weight: 500;" />

        </RadzenPanelMenu>
    </RadzenSidebar>

    <RadzenBody Style="background-color: #f8fafc; padding: 2rem; overflow-y: auto;">
        <div class="container-fluid">
            @Body
        </div>
    </RadzenBody>
</RadzenLayout>

<RadzenDialog />
<RadzenNotification />
<RadzenTooltip />
<RadzenContextMenu />

@code {
    private bool sidebarExpanded = true;
}
